{
  "manifest_version": 3,
  "name": "Vitra Bridge",
  "version": "1.0.0",
  "description": "Đọc vùng chọn, gỡ khóa anti-copy và kết nối an toàn với Vitra Desktop.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "tabs", "webNavigation"],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file:///*",
    "ws://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_title": "Vitra Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_page": "options.html"
}
